#!/bin/bash
set -e

PKG_NAME="venusos-monarch-bms"
PKG_DIR="/data/${PKG_NAME}"
SERVICE_NAME="dbus-monarch-bms"
SERVICE_LINK="/service/${SERVICE_NAME}"
GUI_QML_DIR="/data/apps/${PKG_NAME}/qml"
QML_DST="/data/apps/${PKG_NAME}/qml/PageMonarchBms.qml"

install_pkg() {
    mkdir -p "${PKG_DIR}"
    mkdir -p "${GUI_QML_DIR}"

    chmod +x "${PKG_DIR}/service/run"
    ln -sfn "${PKG_DIR}/service" "${SERVICE_LINK}"

    # Keep QML in a known persistent location.
    cp -f "${PKG_DIR}/qml/PageMonarchBms.qml" "${QML_DST}"

    echo "${PKG_NAME} installed. Service link: ${SERVICE_LINK}"
}

remove_pkg() {
    if [ -L "${SERVICE_LINK}" ] || [ -e "${SERVICE_LINK}" ]; then
        rm -f "${SERVICE_LINK}"
    fi
    echo "${PKG_NAME} removed."
}

case "$1" in
    install)
        install_pkg
        ;;
    uninstall|remove)
        remove_pkg
        ;;
    restart)
        remove_pkg
        install_pkg
        ;;
    *)
        echo "Usage: $0 {install|uninstall|remove|restart}"
        exit 1
        ;;
esac
